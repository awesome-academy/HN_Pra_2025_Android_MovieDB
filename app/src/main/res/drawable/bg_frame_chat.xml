<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#CC0B0B0B"
            android:endColor="#660B0B0B"
            android:type="linear"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
            android:startColor="#1FFFFFFF"
            android:centerColor="#00FFFFFF"
            android:endColor="#00FFFFFF"
            android:type="linear"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#22FFFFFF"/>
        </shape>
    </item>
</layer-list>


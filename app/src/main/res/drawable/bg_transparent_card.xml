<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#08000000"
                android:endColor="#12000000" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item android:bottom="2dp" android:top="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#0AFFFFFF"
                android:centerColor="#06FFFFFF"
                android:endColor="#03FFFFFF" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#18FFFFFF" />
        </shape>
    </item>
</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/searchUserBackground"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".screen.searchUser.SearchUserFragment">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/main_background"
        android:id="@+id/movieThumbnailImageView"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_20"
        android:id="@+id/titleTextViewWatchParty"
        android:paddingTop="@dimen/dp_50"
        android:text="@string/invite_to_watch_party"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/searchTextInputLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50"
        android:layout_marginStart="@dimen/dp_16"
        android:layout_marginEnd="@dimen/dp_16"
        android:layout_below="@id/titleTextViewWatchParty"
        android:hint="@string/search_for_people"
        android:textColorHint="@color/white"
        app:endIconMode="clear_text"
        app:boxCornerRadiusTopStart="@dimen/dp_30"
        app:boxCornerRadiusTopEnd="@dimen/dp_30"
        app:boxCornerRadiusBottomStart="@dimen/dp_30"
        app:boxCornerRadiusBottomEnd="@dimen/dp_30"
        app:boxBackgroundColor="@color/gray">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/searchEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:drawableStart="@drawable/baseline_search_24"
            android:drawablePadding="@dimen/dp_10"
            android:drawableTint="@color/white"
            android:textColor="@color/white" />
    </com.google.android.material.textfield.TextInputLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_80"
        android:id="@+id/recyclerViewWatchPartyChosen"
        android:layout_below="@id/searchTextInputLayout"
        android:scrollbars="horizontal"
        android:orientation="horizontal"
        android:padding="@dimen/dp_10"
        android:scrollbarThumbVertical="@color/purple"
        android:scrollbarTrackVertical="@color/gray_50" />

    <TextView
        android:id="@+id/textViewEmptyStateChosen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/searchTextInputLayout"
        android:text="@string/choose_a_friend"
        android:textSize="@dimen/sp_20"
        android:layout_above="@id/recyclerViewWatchParty"
        android:gravity="center"
        android:textColor="@color/gray_50"
        android:visibility="visible"
        tools:visibility="visible"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewWatchParty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/recyclerViewWatchPartyChosen"
        android:layout_marginTop="4dp"
        android:orientation="vertical"
        android:paddingBottom="@dimen/dp_50"
        android:scrollbarThumbVertical="@color/purple"
        android:scrollbarTrackVertical="@color/gray_50"
        android:scrollbars="vertical" />

    <ProgressBar
        android:id="@+id/progressBarSearch"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone"
        tools:visibility="visible"/>

    <TextView
        android:id="@+id/textViewEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="@string/no_users_found"
        android:textSize="@dimen/sp_20"
        android:textColor="@color/gray_50"
        android:visibility="gone"
        tools:visibility="visible"/>

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/md_blue_500"
        android:layout_marginBottom="@dimen/dp_10"
        android:text="@string/invite"
        android:textAllCaps="true"
        android:id="@+id/inviteButtonWatchParty"
        android:layout_alignBottom="@id/recyclerViewWatchParty"
        android:layout_centerHorizontal="true"/>

</RelativeLayout>
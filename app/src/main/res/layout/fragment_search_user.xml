<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".presentation.searchUser.SearchUserFragment">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/main_background"
        android:id="@+id/movieThumbnailImageView"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_20"
        android:id="@+id/titleTextViewWatchParty"
        android:paddingTop="@dimen/dp_50"
        android:text="@string/invite_to_watch_party"/>

    <com.google.android.material.search.SearchBar
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50"
        android:backgroundTint="@color/gray_50"
        android:id="@+id/searchBarWatchParty"
        android:hint="@string/search_for_people"
        app:titleTextColor="@color/white"
        style="@style/Widget.App.SearchBar"
        android:layout_below="@id/titleTextViewWatchParty"/>

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50"
        android:id="@+id/recyclerViewWatchPartyChosen"
        android:layout_below="@id/searchBarWatchParty"
        android:scrollbars="horizontal"
        android:orientation="horizontal"
        android:scrollbarThumbVertical="@color/purple"
        android:scrollbarTrackVertical="@color/gray_50"
        android:paddingBottom="@dimen/dp_50"/>

    <TextView
        android:id="@+id/textViewEmptyStateChosen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/searchBarWatchParty"
        android:text="@string/choose_a_friend"
        android:textSize="@dimen/sp_20"
        android:textColor="@color/gray_50"
        android:visibility="gone"
        tools:visibility="visible"/>

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/recyclerViewWatchParty"
        android:layout_below="@id/recyclerViewWatchPartyChosen"
        android:scrollbars="vertical"
        android:orientation="vertical"
        android:scrollbarThumbVertical="@color/purple"
        android:scrollbarTrackVertical="@color/gray_50"
        android:paddingBottom="@dimen/dp_50"/>

    <ProgressBar
        android:id="@+id/progressBarSearch"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone"
        tools:visibility="visible"/>

    <TextView
        android:id="@+id/textViewEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="@string/no_users_found"
        android:textSize="@dimen/sp_20"
        android:textColor="@color/gray_50"
        android:visibility="gone"
        tools:visibility="visible"/>

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/md_blue_500"
        android:layout_marginBottom="@dimen/dp_10"
        android:text="@string/invite"
        android:textAllCaps="true"
        android:id="@+id/inviteButtonWatchParty"
        android:layout_alignBottom="@id/recyclerViewWatchParty"
        android:layout_centerHorizontal="true"/>

</RelativeLayout>
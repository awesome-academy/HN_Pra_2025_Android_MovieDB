<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_100"
    android:background="@drawable/bg_item_search"
    android:padding="@dimen/dp_8"
    android:layout_marginVertical="@dimen/dp_4">

    <FrameLayout
        android:id="@+id/framePoster"
        android:layout_width="@dimen/dp_90"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iv_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_poster_placeholder" />

        <TextView
            android:id="@+id/tvQuality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/quality_bg"
            android:textColor="@android:color/white"
            android:textSize="@dimen/sp_10"
            android:textStyle="bold"
            android:paddingHorizontal="@dimen/dp_6"
            android:paddingVertical="@dimen/dp_2"
            android:layout_gravity="bottom|start"
            android:layout_margin="@dimen/dp_4"
            tools:text="HD"/>

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/time_bg"
            android:textColor="@android:color/white"
            android:textSize="@dimen/sp_10"
            android:textStyle="bold"
            android:paddingHorizontal="@dimen/dp_6"
            android:paddingVertical="@dimen/dp_2"
            android:layout_gravity="top|start"
            android:layout_margin="@dimen/dp_4"
            tools:text="120 phút"/>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/framePoster"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="@dimen/dp_12"
        android:layout_marginEnd="@dimen/dp_8">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="THE AUTOPSY OF JANE DOE"
            android:textColor="@android:color/white"
            android:textSize="@dimen/sp_16"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Super-natural Horror"
            android:textColor="#00BFFF"
            android:textSize="@dimen/sp_14"
            android:layout_marginTop="@dimen/dp_4"
            android:maxLines="1"
            android:ellipsize="end"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/dp_6">

            <TextView
                android:id="@+id/tvYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_tag"
                android:textColor="@android:color/white"
                android:textSize="@dimen/sp_10"
                android:textStyle="bold"
                android:paddingHorizontal="@dimen/dp_6"
                android:paddingVertical="@dimen/dp_2"
                tools:text="2024"/>

            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_type_tag"
                android:textColor="@android:color/white"
                android:textSize="@dimen/sp_10"
                android:textStyle="bold"
                android:paddingHorizontal="@dimen/dp_6"
                android:paddingVertical="@dimen/dp_2"
                android:layout_marginStart="@dimen/dp_8"
                tools:text="Phim lẻ"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvCountry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_country_tag"
        android:textColor="@android:color/white"
        android:textSize="@dimen/sp_10"
        android:textStyle="bold"
        android:paddingHorizontal="@dimen/dp_6"
        android:paddingVertical="@dimen/dp_2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="@dimen/dp_4"
        tools:text="US"/>
</androidx.constraintlayout.widget.ConstraintLayout>
